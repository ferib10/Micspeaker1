<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="#0D1B2A">

    <TextView
        android:id="@+id/statusText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="آماده"
        android:textColor="#7EB8D4"
        android:textSize="18sp"
        android:letterSpacing="0.15"
        android:layout_marginBottom="16dp" />

    <FrameLayout
        android:layout_width="220dp"
        android:layout_height="220dp"
        android:layout_marginBottom="16dp">

        <View
            android:layout_width="220dp"
            android:layout_height="220dp"
            android:background="@drawable/circle_outer" />

        <View
            android:layout_width="180dp"
            android:layout_height="180dp"
            android:layout_gravity="center"
            android:background="@drawable/circle_inner" />

        <ToggleButton
            android:id="@+id/toggleButton"
            android:layout_width="140dp"
            android:layout_height="140dp"
            android:layout_gravity="center"
            android:textOn=""
            android:textOff=""
            android:background="@drawable/circle_button"
            android:drawableTop="@drawable/mic_icon"
            android:gravity="center"
            android:checked="false" />

    </FrameLayout>

    <TextView
        android:id="@+id/hintText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="اول به اسپیکر بلوتوث وصل شو"
        android:textColor="#4A7FA5"
        android:textSize="13sp"
        android:layout_marginTop="16dp"
        android:gravity="center" />

    <Button
        android:id="@+id/infoButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="اطلاعات سازنده"
        android:textColor="#4A7FA5"
        android:background="@android:color/transparent"
        android:layout_marginTop="30dp" />

</LinearLayout>